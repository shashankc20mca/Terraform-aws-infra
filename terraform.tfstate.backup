            "id": "1682901313",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::052032053098:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/C6DBE1165F127A23007AA415F391D4D8\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.us-east-1.amazonaws.com/id/C6DBE1165F127A23007AA415F391D4D8:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.us-east-1.amazonaws.com/id/C6DBE1165F127A23007AA415F391D4D8:sub\": \"system:serviceaccount:kube-system:cluster-autoscaler\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::052032053098:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/C6DBE1165F127A23007AA415F391D4D8\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.us-east-1.amazonaws.com/id/C6DBE1165F127A23007AA415F391D4D8:aud\":\"sts.amazonaws.com\",\"oidc.eks.us-east-1.amazonaws.com/id/C6DBE1165F127A23007AA415F391D4D8:sub\":\"system:serviceaccount:kube-system:cluster-autoscaler\"}}}]}",
